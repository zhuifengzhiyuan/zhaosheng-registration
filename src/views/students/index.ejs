<div class="row mb-3">
  <div class="col">
    <h4><i class="bi bi-people-fill"></i> 学生列表</h4>
  </div>
  <div class="col-auto">
    <a href="/students/add" class="btn btn-primary"><i class="bi bi-person-plus-fill"></i> 添加学生</a>
    <button class="btn btn-success" onclick="exportData()"><i class="bi bi-download"></i> 导出数据</button>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/students" class="row g-2">
      <div class="col-md-5">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" class="form-control" name="search" placeholder="搜索姓名 / 身份证 / 学校 / 家长" value="<%= search %>">
        </div>
      </div>
      <div class="col-md-3">
        <select class="form-select" name="admission_type">
          <option value="">全部录取类型</option>
          <option value="正式录取" <%= admissionType === '正式录取' ? 'selected' : '' %>>正式录取</option>
          <option value="自主招生" <%= admissionType === '自主招生' ? 'selected' : '' %>>自主招生</option>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-funnel"></i> 筛选</button>
      </div>
      <div class="col-md-2">
        <a href="/students" class="btn btn-outline-secondary w-100"><i class="bi bi-x-circle"></i> 清除</a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-list-ul"></i> 共 <strong><%= total %></strong> 条记录</span>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover table-striped mb-0">
        <thead class="table-light">
          <tr>
            <th>姓名</th>
            <th>性别</th>
            <th>民族</th>
            <th>录取类型</th>
            <th>身份证号</th>
            <th>中考分数</th>
            <th>毕业学校</th>
            <th>录入人</th>
            <th>录入时间</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% if (students.length === 0) { %>
          <tr><td colspan="10" class="text-center py-4 text-muted">暂无匹配的学生记录</td></tr>
          <% } else { %>
          <% students.forEach(function(s) { %>
          <tr>
            <td><strong><%= s.student_name %></strong></td>
            <td><%= s.gender %></td>
            <td><%= s.ethnicity %></td>
            <td><span class="badge <%= s.admission_type === '正式录取' ? 'bg-success' : 'bg-info' %>"><%= s.admission_type %></span></td>
            <td class="font-monospace small"><%= s.id_number %></td>
            <td><%= s.zhongkao_score %></td>
            <td><%= s.middle_school %></td>
            <td><%= s.creator_name || '未知' %></td>
            <td class="small"><%= new Date(s.created_at).toLocaleString('zh-CN') %></td>
            <td>
              <div class="btn-group btn-group-sm">
                <a href="/students/<%= s.id %>" class="btn btn-outline-primary" title="查看"><i class="bi bi-eye"></i></a>
                <a href="/students/<%= s.id %>/edit" class="btn btn-outline-secondary" title="编辑"><i class="bi bi-pencil"></i></a>
                <button class="btn btn-outline-danger" onclick="deleteStudent(<%= s.id %>, '<%= s.student_name %>')" title="删除"><i class="bi bi-trash"></i></button>
              </div>
            </td>
          </tr>
          <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <% if (totalPages > 1) { %>
  <div class="card-footer">
    <nav>
      <ul class="pagination pagination-sm justify-content-center mb-0">
        <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= page - 1 %><%= search ? '&search=' + search : '' %><%= admissionType ? '&admission_type=' + admissionType : '' %>">上一页</a>
        </li>
        <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= i === page ? 'active' : '' %>">
          <a class="page-link" href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= admissionType ? '&admission_type=' + admissionType : '' %>"><%= i %></a>
        </li>
        <% } %>
        <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
          <a class="page-link" href="?page=<%= page + 1 %><%= search ? '&search=' + search : '' %><%= admissionType ? '&admission_type=' + admissionType : '' %>">下一页</a>
        </li>
      </ul>
    </nav>
  </div>
  <% } %>
</div>
